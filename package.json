{
  "name": "wavekit-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "WaveKit — Unified Wallet Adapter for the XRP Ledger (XRPL).",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/demo"
  ],
  "scripts": {
    "dev": "npm run build && npm run dev --workspace wavekit-demo",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -b tsconfig.build.json",
    "clean": "tsc -b tsconfig.build.json --clean && rm -rf packages/*/dist",
    "test": "node --import tsx --test packages/*/test/*.test.ts"
  },
  "keywords": [
    "xrpl",
    "xrp",
    "wallet",
    "wallet-adapter",
    "web3",
    "xaman",
    "tangem"
  ],
  "license": "MIT",
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
