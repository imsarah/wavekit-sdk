# WaveKit demo — environment variables.
# Copy this file to `.env.local` and fill in what you need, then `npm run dev`.
#
# Everything here is OPTIONAL: with nothing set, the demo runs fully on MOCK
# wallets (offline, no keys). Set these only to exercise the real flows.

# ── Xaman (real wallet) ───────────────────────────────────────────────────────
# Public API key from https://apps.xaman.dev
# In that app's settings, set Origin + Redirect URI to http://localhost:3000.
# Enables the real "Xaman" popup sign-in (OAuth2 PKCE — no secret needed).
NEXT_PUBLIC_XAMAN_API_KEY=

# Xaman API SECRET — SERVER-SIDE ONLY (note: no NEXT_PUBLIC_ prefix, so it never
# reaches the browser). Enables the "Xaman (QR)" flow, where the QR is rendered
# in-app via the /api/xaman route.
XAMAN_API_SECRET=

# ── WalletConnect (only if you wire a real WalletConnect adapter) ─────────────
# Project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ── Merchant webhooks ─────────────────────────────────────────────────────────
# HMAC secret used to sign payment webhooks. Falls back to a demo value if unset.
WAVEKIT_WEBHOOK_SECRET=
